# COD-Odisha Environment Configuration Template
# Copy this file to .env and update values as needed

# Training Configuration
CUDA_VISIBLE_DEVICES=0
BATCH_SIZE=8
LEARNING_RATE=0.0001
EPOCHS=100
IMAGE_SIZE=352

# Dataset Paths
COD10K_ROOT=./data/COD10K
CAMO_ROOT=./data/CAMO
NC4K_ROOT=./data/NC4K
ODISHA_CUSTOM_ROOT=./data/OdishaCustom

# Model Configuration
BACKBONE=resnet50
PRETRAINED=true
CCSIM_OUT_CHANNELS=128
SGFL_OUT_CHANNELS=64

# Logging
WANDB_API_KEY=
USE_WANDB=false
LOG_INTERVAL=50

# Inference
INFERENCE_DEVICE=cuda
CONFIDENCE_THRESHOLD=0.5

# Server
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173

# ============================================================
# Cloud Training Configuration
# ============================================================

# Google Colab — checkpoint persistence on Google Drive
COLAB_CHECKPOINT_DIR=/content/drive/MyDrive/cod-odisha-checkpoints

# Kaggle — output directory
KAGGLE_OUTPUT_DIR=/kaggle/working/cod-odisha-output

# Cloud dataset source (kaggle, direct, or local)
CLOUD_DATASET_SOURCE=kaggle

# Kaggle API (for downloading datasets in Colab)
KAGGLE_USERNAME=
KAGGLE_KEY=
